rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for products
    match /products/{document} {
      allow read: if true;
      allow write: if true; // In production this would be admin-only
    }
    
    // Rules for orders
    match /orders/{document} {
      allow read: if true;
      allow write: if true;
    }
    
    // Rules for notifications
    match /notifications/{document} {
      allow read: if true;
      allow write: if true;
    }
    
    // Rules for users
    match /users/{userId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == 'khdersy808@gmail.com' || 
        request.auth.token.role == 'admin'
      );
    }
    
    // Rules for categories
    match /categories/{document} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == 'khdersy808@gmail.com' || 
        request.auth.token.role == 'admin'
      );
    }

    // Rules for messages
    match /messages/{document} {
      allow create, delete, update: if request.auth != null && (
        request.auth.token.email == 'khdersy808@gmail.com' || 
        request.auth.token.role == 'admin'
      );
      allow read: if request.auth != null && (
        request.auth.token.email == 'khdersy808@gmail.com' || 
        request.auth.token.role == 'admin' ||
        resource.data.receiverId == request.auth.token.email || 
        resource.data.receiverId == 'all'
      );
    }

    // Rules for agents
    match /agents/{document} {
      allow read: if request.auth != null && (
        request.auth.token.email == 'khdersy808@gmail.com' || 
        request.auth.token.role == 'admin' ||
        resource.data.email.toLowerCase() == request.auth.token.email.toLowerCase()
      );
      allow write: if request.auth != null && (
        request.auth.token.email == 'khdersy808@gmail.com' || 
        request.auth.token.role == 'admin'
      );
    }
  }
}
