rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+@?[a-zA-Z0-9_\\-\\.]*$');
    }

    function isOwner(email) {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower() == email.lower();
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && (
               request.auth.token.email.lower() == 'khdersy080@gmail.com' ||
               request.auth.token.email.lower() == 'khdersy808@gmail.com' || (
                 exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) && 
                 get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.role == 'admin'
               )
             );
    }

    // Rules for products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for delivery settings configuration
    match /delivery_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for orders
    match /orders/{orderId} {
      allow create: if true; // Anyone can place an order
      allow read, update, delete: if isAdmin() || (
        isSignedIn() && (
          resource.data.customerEmail.lower() == request.auth.token.email.lower() ||
          (request.resource != null && request.resource.data.customerEmail.lower() == request.auth.token.email.lower())
        )
      );
    }

    // Rules for notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        (resource.data.customerEmail != null && request.auth.token.email != null && resource.data.customerEmail.lower() == request.auth.token.email.lower()) || 
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Rules for users
    match /users/{email} {
      allow read: if isSignedIn() && (isOwner(email) || isAdmin());
      allow create: if isSignedIn() && isOwner(email);
      allow update: if isSignedIn() && (
        (isOwner(email) && (!request.resource.data.keys().hasAll(['role']) || request.resource.data.role == resource.data.role)) || 
        isAdmin() ||
        // Allow updating points and coupons of other users during referral system operations
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'coupons']))
      );
      allow delete: if isAdmin();

      // Rules for user wishlist subcollection
      match /wishlist/{productId} {
        allow read, write: if isOwner(email) || isAdmin();
      }
    }

    // Rules for points history
    match /points_history/{historyId} {
      allow create: if isSignedIn() && (
        request.resource.data.userId.lower() == request.auth.token.email.lower() || 
        isAdmin()
      );
      allow read: if isSignedIn() && (
        resource.data.userId.lower() == request.auth.token.email.lower() || 
        isAdmin()
      );
    }

    // Rules for categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for messages
    match /messages/{messageId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid || 
        isAdmin()
      );
    }

    // Rules for coupons
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for coupon_rules
    match /coupon_rules/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email.lower() == 'khdersy808@gmail.com' || isAdmin());
    }

    // Rules for policies
    match /policies/{policyId} {
      allow read, write: if true;
    }

    // Rules for agents
    match /agents/{agentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for custom product requests
    match /custom_requests/{requestId} {
      allow create: if isSignedIn();
      allow read, write: if isSignedIn() && (
        request.auth.token.email == 'khdersy080@gmail.com' || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }
  }
}
